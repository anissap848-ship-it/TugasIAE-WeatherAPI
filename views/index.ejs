<!DOCTYPE html>
<html>
<head>
    <title>Cuaca Ahfiya</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5 text-center">
    <h2>Weather App Monolith - Tugas IAE</h2>
    <form action="/" method="GET" class="mt-4">
        <input type="text" name="city" placeholder="Nama Kota..." class="form-control w-50 mx-auto mb-2">
        <button type="submit" class="btn btn-primary">Cek Cuaca</button>
    </form>

    <% if (cuaca) { %>
        <div class="card mt-4 p-4 shadow mx-auto" style="width: 18rem;">
            <h3><%= cuaca.name %></h3>
            <h1><%= Math.round(cuaca.main.temp) %>°C</h1>
            <p><%= cuaca.weather[0].description %></p>
        </div>
    <% } %>
</body>
</html>